# Variáveis de Ambiente - iFood Crawler

# Concorrência
CRAWLER_PARALLELISM=5

# Timeouts
CRAWLER_NAVIGATION_TIMEOUT=30
CRAWLER_SELECTOR_TIMEOUT=10

# Retry Policy
CRAWLER_MAX_RETRIES=3
CRAWLER_INITIAL_BACKOFF_MS=1000
CRAWLER_BACKOFF_MULTIPLIER=2.0
CRAWLER_JITTER_MS=200
CRAWLER_MAX_BACKOFF_MS=30000

# Rate Limiting
CRAWLER_RATE_LIMIT_MAX_TOKENS=10
CRAWLER_RATE_LIMIT_REFILL_INTERVAL_MS=1000

# Checkpoint
CRAWLER_CHECKPOINT_INTERVAL=10
CRAWLER_CHECKPOINT_DB_PATH=/app/checkpoints/checkpoint.db

# Arquivos
CRAWLER_INPUT_FILE=/app/urls/ifood_urls.csv
CRAWLER_OUTPUT_FILE=/app/output/results.json

# User Agent
CRAWLER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36"

# Logging
CRAWLER_LOG_LEVEL=INFO
CRAWLER_LOG_FILE=/app/logs/crawler.log

# Java
JAVA_OPTS="-Xmx1G -Xms256M"